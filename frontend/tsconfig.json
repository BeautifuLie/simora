{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "node",
        "noEmit": true,
        "isolatedModules": true,
        "target": "ESNext",
        "jsx": "react-jsx",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "baseUrl": "./src",
        "paths": {
            "@/*": ["*"]
        }
    },
    "include": ["src"]
}
