            "bootstrap": "{{kafka_bootstrap}}",
            "topic": "test-topic",
            "key": "",
            "message": "",
            "headers": [],
            "mode": "consume",
            "group": "",
            "offset": "earliest",
            "saslMechanism": "none",
            "saslUsername": "",
            "saslPassword": "",
