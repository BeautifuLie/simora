            "schemaRegistryUrl": "",
            "schemaRegistrySubject": "",
            "schemaRegistryUsername": "",
            "schemaRegistryPassword": ""
          }
        },
        {
          "id": "qa-kafka-consume-orders",
          "name": "Consume ← orders (earliest)",
          "protocol": "kafka",
          "method": "GET",
          "url": "{{kafka_bootstrap}}",
          "params": [],
          "headers": [],
          "body": "",
          "bodyType": "none",
          "formFields": [],
          "auth": { "type": "none", "token": "", "username": "", "password": "", "headerName": "", "headerValue": "" },
